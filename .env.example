# Copy this file to .env and fill in your values
# ── Local LLM endpoint ────────────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:1234/api/v1/chat
LLM_MODEL=gemma-4-e2b-it
LLM_API_KEY=lm-studio

# ── arXiv polling ─────────────────────────────────────────────────────────────
ARXIV_MAX_RESULTS=5
ARXIV_CATEGORIES=cs.AI,cs.CR,cs.RO,cs.LG

# ── GitHub monitoring ─────────────────────────────────────────────────────────
# Get a free token at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=
GITHUB_REPOS=langchain-ai/langchain,openai/openai-python,anthropics/anthropic-sdk-python,microsoft/autogen,crewAIInc/crewAI

# ── CVE feed (National Vulnerability Database) ────────────────────────────────
# Get API key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
CVE_FEED_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
CVE_MAX_RESULTS=5

# ── RSS / blog feeds (comma-separated, leave empty to use built-in defaults) ──
RSS_FEEDS=
