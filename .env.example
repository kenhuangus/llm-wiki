# Copy this file to .env and fill in your values

# ── Main LLM endpoint ─────────────────────────────────────────────────────────
LLM_MAIN_URL=http://localhost:1234/v1/chat/completions
LLM_MAIN_MODEL=your-model-name
LLM_MAIN_API_KEY=lm-studio

# ── Backup LLM endpoint ───────────────────────────────────────────────────────
LLM_BACKUP_URL=http://localhost:1234/v1/chat/completions
LLM_BACKUP_MODEL=your-backup-model
LLM_BACKUP_API_KEY=lm-studio

# ── arXiv polling ─────────────────────────────────────────────────────────────
ARXIV_MAX_RESULTS=5
ARXIV_CATEGORIES=cs.AI,cs.CR,cs.RO,cs.LG
# Keyword relevance pre-filter: only save papers matching at least one keyword
# Leave empty to disable (save all papers)
ARXIV_KEYWORDS=agent,security,vulnerability,agentic,LLM,multimodal
# Minimum citation count via Semantic Scholar (0 = disabled)
ARXIV_MIN_CITATIONS=0

# ── GitHub monitoring ─────────────────────────────────────────────────────────
# Get a free token at https://github.com/settings/tokens (no scopes for public repos)
# Add security_events scope to enable Dependabot alerts
GITHUB_TOKEN=
GITHUB_REPOS=langchain-ai/langchain,openai/openai-python,anthropics/anthropic-sdk-python,microsoft/autogen,crewAIInc/crewAI

# ── CVE feed (National Vulnerability Database) ────────────────────────────────
# Get API key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
CVE_FEED_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
CVE_MAX_RESULTS=5

# ── RSS / blog feeds ──────────────────────────────────────────────────────────
# Comma-separated feed URLs. Leave empty to use built-in defaults.
RSS_FEEDS=
# Keyword relevance pre-filter for RSS entries (leave empty to save all)
RSS_KEYWORDS=agent,security,LLM,vulnerability,agentic

# ── Semantic Scholar (for arXiv citation count filter) ────────────────────────
# Free tier works without a key; register for higher rate limits
# https://api.semanticscholar.org/api-docs/
S2_API_KEY=
