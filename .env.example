# Copy this file to .env and fill in your values
# Local LLM endpoint (defaults to LM Studio local server)
LLM_BASE_URL=http://localhost:1234/api/v1/chat
LLM_MODEL=gemma-4-e2b-it
LLM_API_KEY=lm-studio

# arXiv polling settings
ARXIV_MAX_RESULTS=3

# GitHub monitoring (optional token for higher rate limits)
GITHUB_TOKEN=

# CVE feed settings
CVE_FEED_URL=https://cve.circl.lu/api/last
CVE_MAX_RESULTS=3
